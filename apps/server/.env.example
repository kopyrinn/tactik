# Server
PORT=3001
NODE_ENV=development

# JWT Secret (change this to any random string)
JWT_SECRET=your-super-secret-jwt-key-change-me-to-random-string

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Dev test user seed (only for local/non-production)
SEED_TEST_USER=true
DEV_TEST_USER_EMAIL=pro@test.local
DEV_TEST_USER_PASSWORD=PunditPro123!
DEV_TEST_USER_NAME=Pro Test User
# Optional ISO date, defaults to 10 years from now
# DEV_TEST_USER_SUBSCRIPTION_END=2036-01-01T00:00:00.000Z

# Second test user for multi-user session checks
SEED_SECOND_TEST_USER=true
DEV_TEST_USER_2_EMAIL=pro2@test.local
DEV_TEST_USER_2_PASSWORD=PunditPro456!
DEV_TEST_USER_2_NAME=Pro Test User 2
# Optional ISO date, defaults to 10 years from now
# DEV_TEST_USER_2_SUBSCRIPTION_END=2036-01-01T00:00:00.000Z

# Database and Redis NOT needed - using SQLite and in-memory store
# Everything works out of the box!
