NODE_ENV=production
PORT=3001

# Обязательно — сгенерируй случайную строку: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# URL фронтенда (для CORS)
FRONTEND_URL=https://tactik.kz,https://www.tactik.kz

# URL для QR-кодов
FRONTEND_QR_URL=https://tactik.kz

# Redis — локальный на том же сервере
REDIS_URL=redis://localhost:6379

# Админка — обязательно поменяй
ADMIN_LOGIN=REPLACE_WITH_ADMIN_LOGIN
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Доверять X-Forwarded-For от Nginx (нужно для rate limiting демо за reverse proxy)
DEMO_START_TRUST_X_FORWARDED_FOR=1
